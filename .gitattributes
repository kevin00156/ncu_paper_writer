# Auto-normalize line endings
* text=auto eol=lf

# Windows-specific files keep CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Unix scripts always LF
*.sh    text eol=lf
Makefile text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

# LaTeX-related
*.tex   text
*.latex text
*.bib   text
*.csl   text
*.cls   text
*.sty   text
